{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "projects": {
    "data-sources": {
      "type": "application",
      "root": "libs/data-sources",
      "entryFile": "index",
      "sourceRoot": "libs/data-sources/src",
      "compilerOptions": {
        "tsConfigPath": "libs/data-sources/tsconfig.lib.json"
      }
    },
    "utils": {
      "type": "library",
      "root": "libs/utils",
      "entryFile": "index",
      "sourceRoot": "libs/utils/src",
      "compilerOptions": {
        "tsConfigPath": "libs/utils/tsconfig.lib.json"
      }
    }
  },
  "compilerOptions": {
    "builder": "webpack",
    "tsConfigPath": "tsconfig.json"
  }
}

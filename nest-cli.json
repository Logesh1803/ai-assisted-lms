{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "projects": {
    "data-sources": {
      "type": "application",
      "root": "libs/data-sources",
      "entryFile": "index",
      "sourceRoot": "libs/data-sources/src",
      "compilerOptions": {
        "tsConfigPath": "libs/data-sources/tsconfig.lib.json"
      }
    },
    "integrations": {
      "type": "application",
      "root": "libs/integrations",
      "entryFile": "index",
      "sourceRoot": "libs/integrations/src",
      "compilerOptions": {
        "tsConfigPath": "libs/integrations/tsconfig.lib.json"
      }
    },
    "message-queues": {
      "type": "library",
      "root": "libs/message-queues",
      "entryFile": "index",
      "sourceRoot": "libs/message-queues/src",
      "compilerOptions": {
        "tsConfigPath": "libs/message-queues/tsconfig.lib.json"
      }
    },
    "notification": {
      "type": "library",
      "root": "libs/notification",
      "entryFile": "index",
      "sourceRoot": "libs/notification/src",
      "compilerOptions": {
        "tsConfigPath": "libs/notification/tsconfig.lib.json"
      }
    },
    "utils": {
      "type": "library",
      "root": "libs/utils",
      "entryFile": "index",
      "sourceRoot": "libs/utils/src",
      "compilerOptions": {
        "tsConfigPath": "libs/utils/tsconfig.lib.json"
      }
    }
  },
  "compilerOptions": {
    "builder": "webpack",
    "tsConfigPath": "tsconfig.json"
  }
}
